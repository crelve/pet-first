require 'json'

# Load app configuration from dart_env
def load_dart_env(flavor = 'prod')
  env_file = File.expand_path("../../dart_env/#{flavor}.env", __dir__)
  config = {}

  if File.exist?(env_file)
    File.readlines(env_file).each do |line|
      next if line.strip.empty? || line.start_with?('#')
      key, value = line.strip.split('=', 2)
      next unless key && value
      config[key] = value.gsub(/^"|"$/, '')  # Remove quotes
    end
  else
    UI.error "⚠️ Config file not found: #{env_file}"
  end

  config
end

# Load prod and dev configurations
PROD_CONFIG = load_dart_env('prod')
DEV_CONFIG = load_dart_env('dev')
PROD_APP_ID = PROD_CONFIG['appId'] || 'kikiki.flutter.template'
DEV_APP_ID = DEV_CONFIG['appId'] || 'kikiki.flutter.template'


default_platform(:ios)

platform :ios do
  # Get app display name from Info.plist
  def get_app_name
    project_root = File.expand_path("../..", __dir__)
    info_plist_path = File.join(project_root, "ios", "Runner", "Info.plist")

    begin
      app_name = sh("cd #{project_root} && /usr/libexec/PlistBuddy -c 'Print CFBundleDisplayName' #{info_plist_path}").strip
      return app_name
    rescue
      # Fallback to CFBundleName if CFBundleDisplayName is not set
      begin
        app_name = sh("cd #{project_root} && /usr/libexec/PlistBuddy -c 'Print CFBundleName' #{info_plist_path}").strip
        return app_name
      rescue
        return "App"
      end
    end
  end

  # Get app version from pubspec.yaml
  def get_app_version
    project_root = File.expand_path("../..", __dir__)
    pubspec_path = File.join(project_root, "pubspec.yaml")

    begin
      pubspec_content = File.read(pubspec_path)
      # Extract version like "2.0.1+6" and split to get "2.0.1"
      version_line = pubspec_content.match(/^version:\s*(.+)$/)[1]
      version = version_line.split('+').first.strip
      UI.message "📦 App version from pubspec.yaml: #{version}"
      return version
    rescue => e
      UI.error "⚠️ Could not read version from pubspec.yaml: #{e.message}"
      return nil
    end
  end

  # Slack notification helper
  def send_slack(message:, success:)
    return unless ENV["SLACK_WEBHOOK_URL"]

    slack(
      message: message,
      success: success,
      slack_url: ENV["SLACK_WEBHOOK_URL"],
      default_payloads: []
    )
  end

  # Handle errors and notify Slack
  error do |lane, exception|
    app_name = get_app_name
    send_slack(
      message: "❌ *#{app_name}* - #{lane} failed: #{exception.message}",
      success: false
    )
  end

  desc "Get App Store Connect API key"
  lane :get_api_key do
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: false
    )
  end

  desc "Upload metadata only (no binary, no screenshots)"
  lane :upload_metadata do
    api_key = get_api_key
    begin
      upload_to_app_store(
        api_key: api_key,
        app_identifier: PROD_APP_ID,
        skip_binary_upload: true,
        skip_screenshots: true,
        force: true,
        precheck_include_in_app_purchases: false
      )
    rescue => e
      if e.message.to_s.include?("could not find an editable version")
        UI.important("⚠️ No editable version — falling back to upload_metadata_live")
        upload_metadata_live
      else
        raise
      end
    end
  end

  # READY_FOR_SALE のアプリに対し、editable な新バージョンを作らずに
  # Live版で編集可能なフィールド (support_url / marketing_url / privacy_url /
  # promotional_text) のみを更新するレーン。description / keywords / name /
  # subtitle は edit_live では更新不可なので nil で送らない。
  desc "Upload metadata to LIVE version (published apps; edit_live-safe fields only)"
  lane :upload_metadata_live do
    api_key = get_api_key

    # fastlane bug workaround: edit_live: true のとき upload_metadata.rb:97 で
    # app_store_version_localizations が未初期化のまま :217 で batch_enqueue(nil) が呼ばれる。
    # nil を [] に変換して ArgumentError を回避する。
    FastlaneCore::QueueWorker.prepend(Module.new do
      def batch_enqueue(jobs)
        super(jobs || [])
      end
    end)

    upload_to_app_store(
      api_key: api_key,
      app_identifier: PROD_APP_ID,
      edit_live: true,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      force: true,
      precheck_include_in_app_purchases: false,
      name: {},
      subtitle: {},
      description: {},
      keywords: {},
      release_notes: {}
    )
  end

  desc "Read code signing certificates and profiles from git repo"
  lane :read_code_signing do
    api_key = get_api_key

    match(
      type: "development",
      readonly: true,
      api_key: api_key,
      git_url: ENV["GIT_URL"],
      app_identifier: ENV["APP_IDENTIFIER"]
    )
  end

  desc "Create new code signing certificates and profiles"
  lane :create_new_code_signing do
    api_key = get_api_key

    match(
      type: "appstore",
      readonly: false,
      api_key: api_key,
      git_url: ENV["GIT_URL"],
      app_identifier: ENV["APP_IDENTIFIER"]
    )
  end

  desc "Regenerate provisioning profiles with updated capabilities"
  lane :regenerate_profiles do
    api_key = get_api_key

    # Regenerate for prod
    match(
      type: "appstore",
      readonly: false,
      api_key: api_key,
      app_identifier: PROD_APP_ID,
      force: true
    )

    # # Regenerate for dev (dev App ID no longer needed)
    # match(
    #   type: "appstore",
    #   readonly: false,
    #   api_key: api_key,
    #   app_identifier: DEV_APP_ID,
    #   force: true
    # )

    UI.success "✅ Provisioning profiles regenerated successfully!"
  end

  desc "Sync certificates and profiles"
  lane :sync_certificates do
    api_key = get_api_key
    match(type: "appstore", readonly: true, api_key: api_key)
  end

  desc "Build and upload to TestFlight (dev environment)"
  lane :release_ios_dev do
    api_key = get_api_key

    # Sync certificates
    match(
      type: "appstore",
      readonly: true,
      api_key: api_key,
      app_identifier: DEV_APP_ID
    )

    # Get the latest build number from TestFlight and increment
    current_build = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: DEV_APP_ID
    )
    new_build_number = current_build + 1

    UI.message "Building dev with build number: #{new_build_number}"

    # Build using Flutter CLI (without flavor, using bundle ID to differentiate)
    # Get project root from Fastfile location (ios/fastlane/Fastfile -> ../..)
    project_root = File.expand_path("../..", __dir__)
    export_options_path = File.join(project_root, "ios", "ExportOptionsDev.plist")

    UI.message "Project root: #{project_root}"
    UI.message "Export options: #{export_options_path}"

    Dir.chdir(project_root) do
      sh("flutter", "build", "ipa",
         "--release",
         "--dart-define-from-file=dart_env/dev.env",
         "--build-number=#{new_build_number}",
         "--export-options-plist=#{export_options_path}")
    end

    # Upload the generated IPA
    ipa_path = Dir.glob(File.join(project_root, "build/ios/ipa/*.ipa")).first

    upload_to_testflight(
      api_key: api_key,
      app_identifier: DEV_APP_ID,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true
    )

    app_name = get_app_name
    send_slack(
      message: "🚀 *#{app_name}* - TestFlight build #{new_build_number} (dev) uploaded!",
      success: true
    )
  end

  desc "Build and upload to TestFlight (prod environment)"
  lane :release_ios_prod do
    api_key = get_api_key

    # Sync certificates
    match(
      type: "appstore",
      readonly: true,
      api_key: api_key,
      app_identifier: PROD_APP_ID
    )

    # Get the latest build number from TestFlight and increment
    current_build = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: PROD_APP_ID
    )
    new_build_number = current_build + 1

    UI.message "Building with build number: #{new_build_number}"

    # Build using Flutter CLI
    # Get project root from Fastfile location (ios/fastlane/Fastfile -> ../..)
    project_root = File.expand_path("../..", __dir__)
    export_options_path = File.join(project_root, "ios", "ExportOptions.plist")

    UI.message "Project root: #{project_root}"
    UI.message "Export options: #{export_options_path}"

    Dir.chdir(project_root) do
      sh("flutter", "build", "ipa",
         "--release",
         "--dart-define-from-file=dart_env/prod.env",
         "--build-number=#{new_build_number}",
         "--export-options-plist=#{export_options_path}")
    end

    # Upload the generated IPA
    ipa_path = Dir.glob(File.join(project_root, "build/ios/ipa/*.ipa")).first

    upload_to_testflight(
      api_key: api_key,
      app_identifier: PROD_APP_ID,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true
    )

    app_name = get_app_name
    send_slack(
      message: "🚀 *#{app_name}* - TestFlight build #{new_build_number} (prod) uploaded!",
      success: true
    )

    # TestFlightテスター確認・自動追加
    company_dir = File.expand_path("~/kikiki/released/company")
    tester_script = File.join(company_dir, "engineering/scripts/check-testflight-testers.py")
    if File.exist?(tester_script)
      UI.message "👥 TestFlightテスター確認中..."
      sh("python3 #{tester_script} --bundle-id #{PROD_APP_ID} --setup --wait", log: false) rescue UI.important "⚠️ TestFlightテスター確認をスキップ（スクリプトエラー）"
    end
  end

  desc "Build and upload to TestFlight (alias for release_ios_prod)"
  lane :beta do
    release_ios_prod
  end

  desc "Build and upload to App Store (prod environment)"
  lane :release do
    api_key = get_api_key

    # Sync certificates
    match(
      type: "appstore",
      readonly: true,
      api_key: api_key,
      app_identifier: PROD_APP_ID
    )

    # Get the latest build number from App Store/TestFlight and increment
    current_build = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: PROD_APP_ID
    )
    new_build_number = current_build + 1

    UI.message "Building for App Store with build number: #{new_build_number}"

    # Build using Flutter CLI
    # Get project root from Fastfile location (ios/fastlane/Fastfile -> ../..)
    project_root = File.expand_path("../..", __dir__)
    export_options_path = File.join(project_root, "ios", "ExportOptions.plist")

    UI.message "Project root: #{project_root}"
    UI.message "Export options: #{export_options_path}"

    Dir.chdir(project_root) do
      sh("flutter", "build", "ipa",
         "--release",
         "--dart-define-from-file=dart_env/prod.env",
         "--build-number=#{new_build_number}",
         "--export-options-plist=#{export_options_path}")
    end

    # Upload the generated IPA
    ipa_path = Dir.glob(File.join(project_root, "build/ios/ipa/*.ipa")).first

    # Step 1: Upload binary only (creates App Store Version)
    UI.message "📦 Step 1/2: Uploading binary to create App Store Version..."
    app_version = get_app_version  # pubspec.yamlからバージョンを取得
    upload_to_app_store(
      api_key: api_key,
      app_identifier: PROD_APP_ID,
      ipa: ipa_path,
      app_version: app_version,  # pubspec.yamlのバージョンを動的に使用
      skip_metadata: true,
      skip_screenshots: true,
      precheck_include_in_app_purchases: false,
      force: true
    )

    # Wait for App Store Connect to process the build
    UI.message "⏳ Waiting 60 seconds for App Store Connect to create the version..."
    sleep(180)

      # Convert screenshot directory names from ARB to App Store Connect format
      UI.message "🔄 Converting screenshot directory names to App Store Connect format..."
      convert_script = File.join(project_root, "scripts/convert_screenshot_directories.sh")
      if File.exist?(convert_script)
        sh(convert_script)
      else
        UI.important "⚠️  Screenshot directory conversion script not found, continuing without conversion..."
      end

    # Step 2: Upload metadata and screenshots with error handling
    # Note: For version 1.0.0, fastlane 2.231+ should handle missing review_attachment_file gracefully
    begin
      UI.message "📝 Step 2/2: Uploading metadata and screenshots..."
      upload_to_app_store(
        api_key: api_key,
        app_identifier: PROD_APP_ID,
        app_version: app_version,  # pubspec.yamlのバージョンを動的に使用
        build_number: new_build_number.to_s,  # ビルドを明示指定
        skip_binary_upload: true,
        skip_screenshots: false,
        screenshots_path: File.join(project_root, "screenshots"),
        overwrite_screenshots: true,
        precheck_include_in_app_purchases: false,
        force: true,

        # 審査提出を自動化
        submit_for_review: true,              # 審査に自動提出
        automatic_release: true,              # 承認後に自動リリース
        submission_information: {
          add_id_info_uses_idfa: false,       # 広告識別子を使用しない
        }
      )
      UI.success "✅ Metadata and screenshots uploaded successfully!"
    rescue => ex
      UI.error "⚠️ Metadata upload failed: #{ex.message}"
      UI.important "📦 Binary was uploaded successfully (Step 1 completed)"
      UI.important "📝 You can update metadata and screenshots manually in App Store Connect:"
      UI.important "   1. Go to https://appstoreconnect.apple.com"
      UI.important "   2. Select your app #{PROD_APP_ID}"
      UI.important "   3. Navigate to version 1.0.0"
      UI.important "   4. Upload screenshots and update metadata manually"
      UI.message ""
      UI.message "💡 This error may occur if:"
      UI.message "   • The version is already in review"
      UI.message "   • App Store Connect needs more time to process the build"
      UI.message "   • There are metadata validation issues"
    end

    # TestFlightテスター確認・自動追加（build をCEOグループに紐付け）
    company_dir = File.expand_path("~/kikiki/released/company")
    tester_script = File.join(company_dir, "engineering/scripts/check-testflight-testers.py")
    if File.exist?(tester_script)
      UI.message "👥 TestFlightテスター確認中..."
      sh("python3 #{tester_script} --bundle-id #{PROD_APP_ID} --setup --wait", log: false) rescue UI.important "⚠️ TestFlightテスター確認をスキップ（スクリプトエラー）"
    end

    app_name = get_app_name
    send_slack(
      message: "🎉 *#{app_name}* - App Store build #{new_build_number} submitted!",
      success: true
    )
  end

  desc "Take screenshots automatically using Flutter integration test (Dart only)"
  lane :take_screenshots do
    # 完全にDartでスクリーンショットを撮影（Swift/XCUITest不要）
    Dir.chdir("../..") do
      UI.message "📸 Starting screenshot capture for 39 languages..."
      UI.message "⏱️ This may take 30-60 minutes"

      # 利用可能なiOSシミュレータを探す（優先順位順）
      device_names = [
        "iPhone 16 Pro Max",
        "iPhone 15 Pro Max",
        "iPhone 15 Pro",
        "iPhone 14 Pro Max"
      ]

      device_id = nil
      device_name = nil

      device_names.each do |name|
        result = sh(
          "xcrun simctl list devices | grep '#{name}' | grep -v 'unavailable' | head -n 1 | awk -F '[()]' '{print $2}'",
          log: false,
          error_callback: ->(result) { nil }
        ).strip

        if !result.empty?
          device_id = result
          device_name = name
          break
        end
      end

      if device_id.nil? || device_id.empty?
        UI.user_error! "❌ No suitable iOS simulator found. Please install iPhone 16 Pro Max or iPhone 15 Pro Max."
      end

      UI.message "📱 Using device: #{device_name} (#{device_id})"

      # すべてのシミュレータをシャットダウン（競合を避けるため）
      UI.message "🔄 Shutting down all simulators..."
      sh("xcrun simctl shutdown all || true", log: false)
      sleep(2)

      # シミュレーターを起動
      UI.message "🚀 Booting simulator..."
      sh("xcrun simctl boot '#{device_id}' || true")
      sleep(3)

      # Flutter integration testを実行
      UI.message "▶️ Running Flutter integration tests..."
      UI.message "   (App will be built automatically)"
      begin
        sh("flutter test -d '#{device_id}' --timeout=60m integration_test/screenshot_test_all_locales.dart")
      rescue => e
        # flutter tool finalizer bug workaround: `flutter test` may exit non-zero
        # after integration tests succeeded, because finalize tries to delete an
        # already-removed temp dir (PathNotFoundException in flutter_test_listener).
        # If screenshots were actually produced, treat as success.
        produced = Dir.glob("screenshots/**/*.png").count
        if produced > 0
          UI.important "⚠️ flutter test exited non-zero but #{produced} screenshots were produced. Treating as success (flutter finalizer bug)."
        else
          raise e
        end
      end
      UI.success "✅ Screenshot capture completed!"

      # 生成されたスクリーンショットの数を表示
      screenshot_count = Dir.glob("screenshots/**/*.png").count
      UI.message "📊 Total screenshots: #{screenshot_count}"
    end

    send_slack(
      message: "📸 Screenshots captured successfully using Flutter integration_test (Dart)!",
      success: true
    )
  end

